{
  "name": "nbp-director",
  "version": "0.1.0",
  "description": "NBP Director — Closed-Loop AI Photography Prompt Compiler",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "dev:ext": "vite -c vite.config.extension.ts",
    "build:ext": "vite build -c vite.config.extension.ts"
  },
  "keywords": [
    "nano-banana-pro",
    "ai-photography",
    "prompt-compiler"
  ],
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.2.0",
    "@types/dom-chromium-ai": "^0.0.17",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  }
}
